# 复制为 .env 并填入真实凭证（.env 已 gitignore，不会提交）

# 必盈 API（推荐）— https://www.biyingapi.com
BIYING_LICENCE=你的licence

# BigQuant（可选）— 格式 AK.SK，到 https://bigquant.com 个人中心获取
BIGQUANT_APIKEY=你的AK.你的SK

# 或分开写：
# BIGQUANT_AK=你的AK
# BIGQUANT_SK=你的SK

# TickFlow（旧方案，可选）
TICKFLOW_API_KEY=tk_你的key

# StockAPI（旧方案，可选）
STOCKAPI_TOKEN=你的token
