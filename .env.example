# 复制为 .env 并填入真实凭证（.env 已 gitignore，不会提交）

# Tushare Pro（v4.0 主数据源）
# 文档：https://tushare.pro/document/2
# 设计：docs/TUSHARE_SECTOR_DESIGN.md
TUSHARE_TOKEN=你的token

# 必盈 API（v3.6 归档，v4.0 起可不再使用）
# 文档：https://www.biyingapi.com/doc_hs
# 接入归档：docs/BIYING_API.md
BIYING_LICENCE=你的licence

# BigQuant（可选）— 格式 AK.SK，到 https://bigquant.com 个人中心获取
BIGQUANT_APIKEY=你的AK.你的SK

# 或分开写：
# BIGQUANT_AK=你的AK
# BIGQUANT_SK=你的SK

# TickFlow（旧方案，可选）
TICKFLOW_API_KEY=tk_你的key

# StockAPI（旧方案，可选）
STOCKAPI_TOKEN=你的token
