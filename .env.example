# 数据库路径（默认 SQLite，后续可换 PostgreSQL）
DATABASE_URL=sqlite:///./data/trend_analysis.db

# 数据源优先级：eastmoney,tonghuashun（逗号分隔，前者优先）
DATA_SOURCE_PRIORITY=eastmoney,tonghuashun

# 同步任务：交易日收盘后执行（cron 表达式，默认工作日 16:30）
SYNC_CRON=30 16 * * 1-5

# API 重试
API_MAX_RETRIES=3
API_RETRY_WAIT_SECONDS=3

# 日志
LOG_LEVEL=INFO
LOG_DIR=./logs
